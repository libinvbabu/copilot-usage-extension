{
  "manifest_version": 3,
  "name": "GitHub Copilot Premium Request Pace",
  "version": "1.0.1",
  "description": "Inline pacing helper for GitHub Copilot premium requests — shows daily budget, pace gap, and projection.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Copilot Pace — Settings"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://github.com/settings/copilot/features*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
